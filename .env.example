# ── Solana Configuration ───────────────────────────────────────────────
# Your Helius or other Solana RPC URL (Devnet recommended)
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Your Oracle Operator private key (Base58 string or [1,2,3...] JSON array)
ORACLE_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# ── AI Providers ───────────────────────────────────────────────────────
# Google Gemini API key (from Google AI Studio)
GEMINI_API_KEY=YOUR_GEMINI_KEY

# OpenAI API key (Optional fallback)
OPENAI_API_KEY=YOUR_OPENAI_KEY

# ── Cloud Deployment (Optional) ────────────────────────────────────────
# Supabase credentials for persistent settings across server restarts
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# Frontend URL for CORS configuration on the backend
# FRONTEND_URL=https://your-app.vercel.app

# Backend API URL for the frontend (Defaults to http://localhost:3001)
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
